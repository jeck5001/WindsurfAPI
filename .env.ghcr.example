# Optional: override the env file path used by docker-compose.ghcr.yml
ENV_FILE=.env

# GHCR image coordinates
IMAGE_NAME=ghcr.io/CHANGE_ME/windsurf-api
IMAGE_TAG=latest

# Host bind mounts on the NAS
APP_DATA_DIR=./.docker-data/data
WINDSURF_DIR=./.docker-data/opt/windsurf
WORKSPACE_DIR=./.docker-data/tmp/windsurf-workspace
REPLICA_ISOLATE=0

# Application runtime
PORT=3003
API_KEY=
DATA_DIR=/data
CODEIUM_API_KEY=
CODEIUM_AUTH_TOKEN=
LS_BINARY_PATH=/opt/windsurf/language_server_linux_x64
LS_PORT=42100
DASHBOARD_PASSWORD=
CODEIUM_API_URL=https://server.self-serve.windsurf.com
DEFAULT_MODEL=claude-4.5-sonnet-thinking
MAX_TOKENS=8192
LOG_LEVEL=info
